{
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "src/__tests__"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  }
}
