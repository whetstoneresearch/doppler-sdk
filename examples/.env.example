# Doppler SDK Examples Configuration

# Your wallet private key (keep this secret!)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC endpoint for your target chain
# Base Mainnet
RPC_URL=https://mainnet.base.org

# Multicurve fee examples
# Set ASSET_ADDRESS to one launched multicurve token for fee collection.
# Set ASSET_ADDRESSES to a comma-separated list for multi-token fee previews.
# ASSET_ADDRESS=0xYOUR_ASSET_ADDRESS_HERE
# ASSET_ADDRESSES=0xASSET_ADDRESS_1,0xASSET_ADDRESS_2
# BENEFICIARY_ADDRESS=0xBENEFICIARY_ADDRESS
# PENDING_FEES_TOKEN_BATCH_SIZE=25

# Base mainnet safety guard (used by decay base-mainnet examples)
# CONFIRM_BASE_MAINNET=true
# Optional launch-script toggle:
# If true, examples/multicurve-decay-base-mainnet-launch.ts broadcasts;
# if false/omitted, that script runs simulation-only mode.
# EXECUTE_MAINNET=false

# Alternative RPC endpoints:
# Base Sepolia Testnet
# RPC_URL=https://sepolia.base.org

# Ethereum Sepolia (used by examples/multicurve-scheduled-eth-sepolia.ts)
# ETH_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# ALCHEMY_API_KEY=YOUR_API_KEY
# ETH_SEPOLIA_START_DELAY_SECONDS=0
# Optional: set false for simulation-only (default behavior is to broadcast)
# EXECUTE_ETH_SEPOLIA=false
#
# ETH Sepolia swap + transfer example:
# TOKEN_ADDRESS=0xYOUR_LAUNCHED_TOKEN
# Optional overrides (SDK has defaults for ETH Sepolia):
# ETH_SEPOLIA_UNIVERSAL_ROUTER=0xYOUR_UNIVERSAL_ROUTER
# ETH_SEPOLIA_V4_QUOTER=0xYOUR_V4_QUOTER
# SWAP_AMOUNT_IN_ETH=0.001
# SWAP_SLIPPAGE_BPS=500
# EXECUTE_SWAP=true
# TRANSFER_TO=0xRECIPIENT
# TRANSFER_AMOUNT_TOKENS=1
# EXECUTE_TRANSFER=true

# Ethereum Mainnet
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Custom RPC
# RPC_URL=https://your-custom-rpc-endpoint.com

# Solana examples
# Explicit network selector: devnet or custom.
# Most checked-in Solana examples target the current Doppler devnet deployment.
# SOLANA_NETWORK=devnet
# SOLANA_KEYPAIR_PATH=/path/to/solana-keypair.json
# SOLANA_KEYPAIR=[1,2,...64 byte secret key JSON array]
# Optional endpoint overrides. Required when SOLANA_NETWORK=custom.
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WS_URL=wss://api.devnet.solana.com
# Required when SOLANA_NETWORK=custom:
# SOLANA_CPMM_PROGRAM_ID=CPMM_PROGRAM_ID
# SOLANA_INITIALIZER_PROGRAM_ID=INITIALIZER_PROGRAM_ID
# SOLANA_CPMM_MIGRATOR_PROGRAM_ID=CPMM_MIGRATOR_PROGRAM_ID
# SOLANA_CPMM_HOOK_PROGRAM_ID=CPMM_HOOK_PROGRAM_ID
# SOLANA_COSIGNER_HOOK_PROGRAM_ID=COSIGNER_HOOK_PROGRAM_ID
# Optional override so launch examples do not need CoinGecko:
# SOL_PRICE_USD=150
# Required by examples/solana-swap.ts:
# MINT_0=So11111111111111111111111111111111111111112
# MINT_1=TOKEN_MINT
# SWAP_DIRECTION=0
# AMOUNT_IN=1000000
# Optional for examples/solana-cosigner-gated-launch.ts:
# COSIGNER_KEYPAIR_PATH=/path/to/cosigner-keypair.json
# COSIGNER_KEYPAIR=[1,2,...64 byte secret key JSON array]
# Optional for examples/solana-cosigner-gated-buy.ts:
# SOLANA_COSIGNER_BUY_AMOUNT_SOL=0.2
# Required by examples/solana-usdc-e2e-launch.ts and examples/solana-usdc-cosigner-gated-buy.ts:
# The payer's devnet USDC ATA must be funded before running.
# SOLANA_COSIGNER_BUY_AMOUNT_USDC=0.2
# Required by cosigner gated-buy examples:
# SOLANA_FEE_BENEFICIARY_1_WALLET=BENEFICIARY_WALLET
# SOLANA_FEE_BENEFICIARY_1_BASE_AMOUNT=140000000
# SOLANA_FEE_BENEFICIARY_1_SHARE_BPS=7000
# SOLANA_FEE_BENEFICIARY_2_WALLET=BENEFICIARY_WALLET
# SOLANA_FEE_BENEFICIARY_2_BASE_AMOUNT=60000000
# SOLANA_FEE_BENEFICIARY_2_SHARE_BPS=3000
